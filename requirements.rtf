def score_nutrient(v, mn, mx):\
    if v >= mn and v <= mx: return 2\
    if (v >= mn*0.7 and v < mn) or (v > mx and v <= mx*1.3): return 1\
    return 0\
\
def fert_advice(nut, cur, req_min):\
    gap = req_min - cur\
    if gap <= 0: return "\uc0\u9989  No addition needed"\
    if nut == "N": return f"Add \{gap\} kg/ha N \uc0\u8594  \{round(gap/0.46,1)\} kg/ha Urea"\
    if nut == "P": return f"Add \{gap\} kg/ha P \uc0\u8594  \{round(gap/0.16,1)\} kg/ha SSP"\
    if nut == "K": return f"Add \{gap\} kg/ha K \uc0\u8594  \{round(gap/0.60,1)\} kg/ha MOP"\
