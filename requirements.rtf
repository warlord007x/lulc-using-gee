@st.cache_resource\
def get_roi():\
    return ee.Geometry.Point([CENTER_LON, CENTER_LAT]).buffer(35000)\
\
@st.cache_resource\
def build_s2(cache_key, start, end, cloud_pct):\
    roi = get_roi()\
    s2 = (ee.ImageCollection("COPERNICUS/S2_SR")\
          .filterBounds(roi)\
          .filterDate(start, end)\
          .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", cloud_pct))\
          .select(["B2", "B3", "B4", "B8"])\
          .median()\
          .clip(roi))\
    ndvi = s2.normalizedDifference(["B8", "B4"]).rename("NDVI")\
    ndwi = s2.normalizedDifference(["B3", "B8"]).rename("NDWI")\
    return s2.addBands([ndvi, ndwi])\
\
@st.cache_resource\
def get_training_fc():\
    # All 10 exact training points from your Colab notebook\
    return ee.FeatureCollection([\
        ee.Feature(ee.Geometry.Point([72.79, 18.89]), \{"class": 1\}),  # Water\
        ee.Feature(ee.Geometry.Point([72.81, 18.92]), \{"class": 1\}),  # Water\
        ee.Feature(ee.Geometry.Point([72.86, 18.90]), \{"class": 1\}),  # Water\
        ee.Feature(ee.Geometry.Point([72.92, 19.25]), \{"class": 2\}),  # Dense Veg (SGNP)\
        ee.Feature(ee.Geometry.Point([72.95, 19.28]), \{"class": 2\}),  # Dense Veg (SGNP)\
        ee.Feature(ee.Geometry.Point([72.88, 19.15]), \{"class": 3\}),  # Light Veg\
        ee.Feature(ee.Geometry.Point([72.84, 19.18]), \{"class": 3\}),  # Light Veg\
        ee.Feature(ee.Geometry.Point([72.88, 19.08]), \{"class": 4\}),  # Built-up\
        ee.Feature(ee.Geometry.Point([72.90, 19.05]), \{"class": 4\}),  # Built-up\
        ee.Feature(ee.Geometry.Point([73.02, 19.22]), \{"class": 6\}),  # Agriculture\
    ])\
\
@st.cache_resource\
def classify(cache_key, start, end, cloud_pct):\
    """Build composite + train RF + classify. Returns (classified_image, s2_composite)"""\
    s2       = build_s2(cache_key, start, end, cloud_pct)\
    train_fc = get_training_fc()\
    training = s2.sampleRegions(collection=train_fc, properties=["class"], scale=10)\
    clf      = ee.Classifier.smileRandomForest(200).train(training, "class", BANDS)\
    return s2.classify(clf), s2\
\
